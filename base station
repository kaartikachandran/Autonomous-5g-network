#include <Wire.h>
#include <LiquidCrystal_PCF8574.h>
#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <HTTPClient.h>

// WiFi credentials
const char* ssid = "Shrivai";
const char* password = "Vaishu@2007";

// Firebase
const char* firebaseHost = "autonomous-5g-network-default-rtdb.asia-southeast1.firebasedatabase.app";

// TCP Server
WiFiServer server(1234);

// LCD
LiquidCrystal_PCF8574 lcd(0x27);

// LED Pins
#define GREEN_LED 2
#define RED_LED 4

// Packet variables
int nodeID = 0;
int packetID = 0;
long latency = 0;
long rssi = 0;

// Send data to Firebase
void sendToFirebase(int nodeID, int packetID, long latency, long rssi) {
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient https;

  String url = "https://" + String(firebaseHost) + "/node" + String(nodeID) + "/packets.json";
  String jsonData = "{\"packetID\":" + String(packetID) + ",\"latency\":" + String(latency) + ",\"rssi\":" + String(rssi) + "}";

  https.begin(client, url);
  https.addHeader("Content-Type", "application/json");
  int httpCode = https.POST(jsonData);

  if(httpCode > 0) Serial.println("✅ Firebase Updated");
  else Serial.println("❌ Firebase Error");

  https.end();
}

// LED Control
void updateLED(long latency) {
  if (latency < 100) {
    digitalWrite(GREEN_LED, HIGH);
    digitalWrite(RED_LED, LOW);
  }
  else if (latency < 300) {
    digitalWrite(RED_LED, LOW);
    digitalWrite(GREEN_LED, millis() % 400 < 200);
  }
  else {
    digitalWrite(GREEN_LED, LOW);
    digitalWrite(RED_LED, HIGH);
  }
}

void setup() {
  Serial.begin(115200);

  Wire.begin(21, 22);
  Wire.setClock(100000);

  pinMode(GREEN_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  lcd.begin(16,2);
  lcd.setBacklight(255);

  lcd.setCursor(0,0);
  lcd.print("BASE STATION");
  lcd.setCursor(0,1);
  lcd.print("Connecting...");

  // 🔥 WiFi Connection with DEBUG
  Serial.println("Connecting to WiFi...");
  WiFi.begin(ssid, password);

  while(WiFi.status() != WL_CONNECTED){
    delay(500);
    Serial.print(".");
  }

  Serial.println("\n✅ WiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  // Show IP on LCD
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("IP:");
  lcd.print(WiFi.localIP());

  delay(3000);

  // Start TCP Server
  server.begin();
  Serial.println("✅ TCP Server Started");

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Waiting UE...");
}

void loop() {
  WiFiClient client = server.available();

  if(client){
    Serial.println("🔥 CLIENT CONNECTED!");

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("UE Connected");

    while(client.connected()){
      if(client.available()){
        String msg = client.readStringUntil('\n');
        msg.trim();
        Serial.println("RX: " + msg);

        unsigned long recvTime = millis();
        long sendTime;

        sscanf(msg.c_str(), "NODE:%d,PKT:%d,TIME:%ld", &nodeID, &packetID, &sendTime);

        latency = recvTime - sendTime;
        rssi = WiFi.RSSI();

        sendToFirebase(nodeID, packetID, latency, rssi);
        updateLED(latency);

        lcd.setCursor(0,0);
        lcd.print("N:");
        lcd.print(nodeID);
        lcd.print(" R:");
        lcd.print(rssi);
        lcd.print("   ");

        lcd.setCursor(0,1);
        lcd.print("L:");
        lcd.print(latency);
        lcd.print(" P:");
        lcd.print(packetID);
        lcd.print("   ");

        client.println("ACK");
      }
    }

    client.stop();
    Serial.println("Client Disconnected");

    digitalWrite(GREEN_LED, LOW);
    digitalWrite(RED_LED, LOW);

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("Waiting UE...");
  }
}
